<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer green circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#00E5A0" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
    <!-- Inner white circle with stroke -->
    <item android:gravity="center" android:width="32dp" android:height="32dp">
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="@color/white" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Solid white checkmark -->
    <item android:gravity="center" android:width="24dp" android:height="24dp">
        <vector android:width="24dp" android:height="24dp" android:viewportWidth="24" android:viewportHeight="24">
            <path
                android:fillColor="@color/white"
                android:pathData="M9,16.2L4.8,12l-1.4,1.4L9,19 21,7l-1.4,-1.4L9,16.2z" />
        </vector>
    </item>
</layer-list>
