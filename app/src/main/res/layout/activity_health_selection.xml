<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_gray" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.1"
            android:text="STEP 2 OF 3"
            android:textAlignment="center"
            android:textColor="@color/text_gray"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="24dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progress="66"
        android:progressBackgroundTint="#E0E0E0"
        android:progressTint="@color/primary_green" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Applicable Health\nRisk Categories"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:text="Choose one or more categories that reflect your\nhealth background to personalize evaluation."
                android:textColor="@color/text_gray"
                android:textSize="14sp" />

            <!-- Category Container -->
            <LinearLayout
                android:id="@+id/llCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- Dynamite category items will be added here or statically defined below -->
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Blood Sugar Regulation"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Cardiovascular &amp; Circulatory Health"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Hormonal &amp; Metabolic Health"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Digestive &amp; Organ Health"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Allergy &amp; Immune Sensitivity"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="No Specific Condition"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCat7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <CheckBox
                    android:id="@+id/cbCat7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:paddingStart="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:text="Not Sure"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="24dp"
                android:background="#E0E0E0" />

            <!-- Find Category Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.1"
                android:text="FIND MY CATEGORY (OPTIONAL)"
                android:textColor="@color/text_gray"
                android:textSize="10sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary_green"
                app:boxStrokeWidth="1dp"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type your condition (e.g., thyroid, kidney)"
                    android:inputType="text"
                    android:textColorHint="@color/text_gray" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Search Suggestion Result -->
            <LinearLayout
                android:id="@+id/llSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_green_recommendation"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suggested Category:"
                        android:textColor="@color/primary_green"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvSuggestedCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hormonal &amp; Metabolic Health"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplySuggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_green"
                    android:minWidth="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Apply"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:text="This tool helps map your condition to ingredient risk categories. It does not provide medical diagnosis."
                android:textColor="@color/text_gray"
                android:textSize="10sp"
                android:textStyle="italic" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:padding="24dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/primary_green"
            android:text="Continue"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textEnd" />
    </LinearLayout>

</LinearLayout>

